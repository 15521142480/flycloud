.message-item.data-v-7b6b402a {
  margin-bottom: 10rpx;
}
.date-message.data-v-7b6b402a,
.system-message.data-v-7b6b402a {
  width: -webkit-fit-content;
  width: fit-content;
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
  margin-bottom: 16rpx;
  background-color: var(--ui-BG-3);
  color: #999;
  font-size: 24rpx;
}
.chat-avatar.data-v-7b6b402a {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
}
.send-status.data-v-7b6b402a {
  color: #333;
  height: 80rpx;
  margin-right: 8rpx;
  display: flex;
  align-items: center;
}
.send-status .loading.data-v-7b6b402a {
  width: 32rpx;
  height: 32rpx;
  animation: rotating-7b6b402a 2s linear infinite;
}
@keyframes rotating-7b6b402a {
0% {
    transform: rotateZ(0);
}
100% {
    transform: rotateZ(360deg);
}
}
.send-status .warning.data-v-7b6b402a {
  width: 32rpx;
  height: 32rpx;
  color: #ff3000;
}
.message-box.data-v-7b6b402a {
  max-width: 50%;
  font-size: 16px;
  white-space: normal;
  word-break: break-all;
  word-wrap: break-word;
  padding: 20rpx;
  color: #fff;
  background: linear-gradient(90deg, var(--ui-BG-Main), var(--ui-BG-Main-gradient));
  margin-top: 3px;
  margin-bottom: 9px;
  border-top-left-radius: 10px;
  border-bottom-right-radius: 10px;
  border-bottom-left-radius: 10px;
}
.message-box.admin.data-v-7b6b402a {
  background: #fff;
  color: #333;
  margin-top: 3px;
  margin-bottom: 9px;
  border-radius: 0 10px 10px 10px;
}
.message-box.data-v-7b6b402a  .imgred {
  width: 100%;
}
.message-box.data-v-7b6b402a  .imgred,
.message-box.data-v-7b6b402a  img {
  width: 100%;
}
.data-v-7b6b402a  .goods,.data-v-7b6b402a  .order {
  max-width: 500rpx;
}
.message-img.data-v-7b6b402a {
  width: 100px;
  height: 100px;
  border-radius: 6rpx;
}
.error-img.data-v-7b6b402a {
  width: 400rpx;
  height: 400rpx;
}