.s-category.data-v-1031f1cf  .side-menu-wrap {
  width: 200rpx;
  height: 100%;
  padding-left: 12rpx;
  background-color: #f6f6f6;
  position: fixed;
  left: 0;
}
.s-category.data-v-1031f1cf  .side-menu-wrap .menu-item {
  width: 100%;
  height: 88rpx;
  position: relative;
  transition: all linear 0.2s;
}
.s-category.data-v-1031f1cf  .side-menu-wrap .menu-item .menu-title {
  line-height: 32rpx;
  font-size: 30rpx;
  font-weight: 400;
  color: #333;
  margin-left: 28rpx;
  position: relative;
  z-index: 0;
}
.s-category.data-v-1031f1cf  .side-menu-wrap .menu-item .menu-title::before {
  content: "";
  width: 64rpx;
  height: 12rpx;
  background: linear-gradient(90deg, var(--ui-BG-Main-gradient), var(--ui-BG-Main-light)) !important;
  position: absolute;
  left: -64rpx;
  bottom: 0;
  z-index: -1;
  transition: all linear 0.2s;
}
.s-category.data-v-1031f1cf  .side-menu-wrap .menu-item.menu-item-active {
  background-color: #fff;
  border-radius: 20rpx 0 0 20rpx;
}
.s-category.data-v-1031f1cf  .side-menu-wrap .menu-item.menu-item-active::before {
  content: "";
  position: absolute;
  right: 0;
  bottom: -20rpx;
  width: 20rpx;
  height: 20rpx;
  background: radial-gradient(circle at 0 100%, transparent 20rpx, #fff 0);
}
.s-category.data-v-1031f1cf  .side-menu-wrap .menu-item.menu-item-active::after {
  content: "";
  position: absolute;
  top: -20rpx;
  right: 0;
  width: 20rpx;
  height: 20rpx;
  background: radial-gradient(circle at 0% 0%, transparent 20rpx, #fff 0);
}
.s-category.data-v-1031f1cf  .side-menu-wrap .menu-item.menu-item-active .menu-title {
  font-weight: 600;
}
.s-category.data-v-1031f1cf  .side-menu-wrap .menu-item.menu-item-active .menu-title::before {
  left: 0;
}
.s-category.data-v-1031f1cf  .goods-list-box {
  background-color: #fff;
  width: calc(100vw - 200rpx);
  padding: 10px;
  margin-left: 200rpx;
}
.s-category.data-v-1031f1cf  .banner-img {
  width: calc(100vw - 130px);
  border-radius: 5px;
  margin-bottom: 20rpx;
}