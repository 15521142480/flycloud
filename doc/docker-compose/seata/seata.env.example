# 复制为 /docker/config/seata/seata.env 并填写实际值。该文件必须加入服务器忽略列表，不提交 Git。

# Seata 注册到 Nacos 的地址：填写业务服务可访问到的 Docker 宿主机内网 / 公网 IP，不能写 127.0.0.1。
SEATA_IP=CHANGE_ME
SEATA_PORT=8091

# Docker 网络内连接 Nacos；若 Seata 与 Nacos 不在同一 Compose 网络，改为可达 IP:端口。
NACOS_SERVER_ADDR=nacos_one:8848
NACOS_NAMESPACE=
SEATA_NACOS_GROUP=SEATA_GROUP
NACOS_USERNAME=nacos
NACOS_PASSWORD=CHANGE_ME

# Seata Console 与接口鉴权。请使用密码管理工具生成并保存，不要使用示例值。
SEATA_CONSOLE_USERNAME=seata
SEATA_CONSOLE_PASSWORD=CHANGE_ME
SEATA_SECURITY_SECRET_KEY=CHANGE_ME

# 容器内日志目录；实际日志通过 Compose 映射到 /docker/config/seata/logs。
SEATA_LOG_PATH=/seata-server/logs
