# 复制为 /docker/config/seata/seata.env 并填写实际值。该文件必须加入服务器忽略列表，不提交 Git。


# 1、事务协调器TC服务 -> seata-server
# Seata 服务器地址
SEATA_IP=CHANGE_ME
SEATA_PORT=8091

# Docker 网络内连接 Nacos；若 Seata 与 Nacos 不在同一 Compose 网络，改为可达 IP:端口。
NACOS_SERVER_ADDR=localhost:8848
NACOS_NAMESPACE=
SEATA_NACOS_GROUP=SEATA_GROUP
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# Seata 的MySQL配置
SEATA_DB_HOST=localhost
SEATA_DB_PORT=3306
SEATA_DB_USERNAME=root
SEATA_DB_PASSWORD=root
SEATA_DB_NAME=fly_seata

# 容器内日志目录；实际日志通过 Compose 映射到 /docker/config/seata/logs。
SEATA_LOG_PATH=/seata-server/logs


# 2、可选：Console / 原生注册中心 -> seata-naming-server:8081
# 仅在需要 Seata Console 或改用 Seata 原生注册中心时部署；它不是业务客户端。
# 账号、密码和鉴权密钥请使用密码管理工具生成并保存。
# SEATA_CONSOLE_USERNAME=seata
# SEATA_CONSOLE_PASSWORD=seata
# SEATA_SECURITY_SECRET_KEY=32位随机数
